{% extends 'base.html.twig' %}

{% block title %}{{ title|default('Catàleg de Productes') }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="fw-bold">{{ title|default('Catàleg de Productes') }}</h1>
        {% if show_new_button|default(false) and app.user %}
            <a href="{{ path('app_product_new') }}" class="btn btn-success shadow-sm">
                <i class="bi bi-plus-circle"></i> Publicar Producte
            </a>
        {% endif %}
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 text-dark">
        {% for product in products %}
            <div class="col">
                <div class="card h-100 shadow-sm border-0 transition-hover">
                    {% if product.image %}
                        <img src="{{ product.image }}" class="card-img-top" alt="{{ product.title }}" style="height: 200px; object-fit: cover;">
                    {% else %}
                        <div class="bg-secondary text-white d-flex align-items-center justify-content-center" style="height: 200px;">
                            <i class="bi bi-image fs-1"></i>
                        </div>
                    {% endif %}
                    <div class="card-body">
                        <h5 class="card-title fw-bold text-truncate mb-1">{{ product.title }}</h5>
                        <p class="card-text text-muted small mb-3">
                            {{ product.description|length > 80 ? product.description|slice(0, 80) ~ '...' : product.description }}
                        </p>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="fs-5 fw-bold text-primary">{{ product.price|number_format(2, ',', '.') }}€</span>
                            <span class="badge bg-light text-dark border">{{ product.createdAt|date('d/m/Y') }}</span>
                        </div>
                    </div>
                    <div class="card-footer bg-white border-top-0 pb-3">
                        <div class="d-flex align-items-center mb-2">
                             <small class="text-muted">Per: <strong>{{ product.owner.name }}</strong></small>
                        </div>
                        
                        <div class="d-grid gap-2">
                            <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn btn-outline-primary btn-sm">Veure Detalls</a>
                            
                            {% if show_actions|default(false) and app.user == product.owner %}
                                <div class="d-flex gap-2">
                                    <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-warning btn-sm flex-grow-1">Editar</a>
                                    {{ include('product/_delete_form.html.twig') }}
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <div class="mb-3">
                    <i class="bi bi-box-seam display-1 text-muted"></i>
                </div>
                <p class="fs-4 text-muted">{{ empty_message|default('No s\'han trobat productes.') }}</p>
                {% if show_new_button|default(false) %}
                    <a href="{{ path('app_product_new') }}" class="btn btn-primary btn-lg px-4 shadow-sm">Publica el teu primer producte!</a>
                {% endif %}
            </div>
        {% endfor %}
    </div>
{% endblock %}
