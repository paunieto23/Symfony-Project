{% extends 'base.html.twig' %}

{% block title %}Editar Producte{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 p-4">
                <h1 class="h3 mb-4 fw-bold">✏️ Editar Producte</h1>

                {{ include('product/_form.html.twig', {'button_label': 'Actualitzar Producte'}) }}

                <hr class="my-4">
                <div class="d-flex justify-content-between align-items-center">
                    <a href="{{ path('app_product_index') }}" class="btn btn-link text-decoration-none px-0">
                        &larr; Tornar al llistat
                    </a>
                    {{ include('product/_delete_form.html.twig') }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
