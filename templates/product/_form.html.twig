{{ form_start(form) }}
    <div class="mb-3">
        {{ form_label(form.title, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.title, {'attr': {'class': 'form-control form-control-lg'}}) }}
        {{ form_errors(form.title) }}
    </div>

    <div class="mb-3">
        {{ form_label(form.description, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': 6}}) }}
        {{ form_errors(form.description) }}
    </div>

    <div class="row">
        <div class="col-md-6 mb-3">
            {{ form_label(form.price, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
            <div class="input-group">
                {{ form_widget(form.price, {'attr': {'class': 'form-control border-end-0'}}) }}
                <span class="input-group-text bg-white border-start-0 text-primary fw-bold">€</span>
            </div>
            {{ form_errors(form.price) }}
        </div>
        <div class="col-md-6 mb-3">
            {{ form_label(form.image, null, {'label_attr': {'class': 'form-label fw-bold'}}) }}
            {{ form_widget(form.image, {'attr': {'class': 'form-control', 'placeholder': 'https://picsum.photos/...'}}) }}
            {{ form_errors(form.image) }}
        </div>
    </div>

    <div class="mt-4">
        <button class="btn btn-primary btn-lg w-100 shadow-sm">{{ button_label|default('Publicar Producte') }}</button>
    </div>
{{ form_end(form) }}
