{% extends 'base.html.twig' %}

{% block title %}Registrar-se{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-0 p-4">
            <h1 class="h3 mb-4 fw-bold text-center">📝 Crea el teu compte</h1>

            {{ form_errors(registrationForm) }}

            {{ form_start(registrationForm) }}
                <div class="mb-3">
                    {{ form_label(registrationForm.name, 'Nom Complet', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.name) }}
                    {{ form_errors(registrationForm.name) }}
                </div>
                <div class="mb-3">
                    {{ form_label(registrationForm.email, 'Correu electrònic', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.email) }}
                    {{ form_errors(registrationForm.email) }}
                </div>
                <div class="mb-3">
                    {{ form_label(registrationForm.plainPassword, 'Contrasenya', {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(registrationForm.plainPassword) }}
                    {{ form_errors(registrationForm.plainPassword) }}
                </div>
                <div class="mb-4 form-check">
                    {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'form-check-input'}}) }}
                    {{ form_label(registrationForm.agreeTerms, 'Accepto els termes i condicions', {'label_attr': {'class': 'form-check-label'}}) }}
                    {{ form_errors(registrationForm.agreeTerms) }}
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100">Registrar-se</button>
            {{ form_end(registrationForm) }}

            <div class="mt-3 text-center">
                Ja tens compte? <a href="{{ path('app_login') }}">Inicia sessió</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}
